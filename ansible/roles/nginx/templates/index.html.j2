<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ nginx_site_title }}</title>
  <style>
    :root { color-scheme: dark; }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: radial-gradient(circle at 30% 20%, #1e293b, #0f172a 60%, #020617);
      color: #e2e8f0;
      padding: 1.5rem;
    }
    .card {
      max-width: 640px;
      width: 100%;
      background: rgba(30, 41, 59, 0.6);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(148, 163, 184, 0.15);
      border-radius: 20px;
      padding: 3rem 2.5rem;
      box-shadow: 0 25px 60px rgba(0, 0, 0, 0.5);
      text-align: center;
    }
    h1 { font-size: 1.7rem; line-height: 1.3; margin-bottom: 1rem; }
    p.tagline { color: #94a3b8; font-size: 1.05rem; margin-bottom: 2rem; }
    .stack { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; margin-bottom: 2rem; }
    .badge {
      padding: 0.5rem 1rem;
      border-radius: 999px;
      font-size: 0.85rem;
      font-weight: 600;
      border: 1px solid rgba(148, 163, 184, 0.25);
    }
    .tf { background: rgba(124, 58, 237, 0.15); color: #c4b5fd; }
    .ans { background: rgba(220, 38, 38, 0.15); color: #fca5a5; }
    .aws { background: rgba(245, 158, 11, 0.15); color: #fcd34d; }
    .meta {
      font-size: 0.8rem;
      color: #64748b;
      border-top: 1px solid rgba(148, 163, 184, 0.15);
      padding-top: 1.25rem;
    }
    .meta code { color: #cbd5e1; }
  </style>
</head>
<body>
  <main class="card">
    <h1>{{ nginx_site_heading }}</h1>
    <p class="tagline">{{ nginx_site_tagline }}</p>
    <div class="stack">
      <span class="badge tf">Terraform</span>
      <span class="badge ans">Ansible</span>
      <span class="badge aws">AWS EC2 · Nginx</span>
    </div>
    <div class="meta">
      Served by <code>{{ ansible_hostname | default('this host') }}</code>
      &middot; Deployed {{ ansible_date_time.date | default('') }}
      &middot; Maintained by {{ nginx_site_author }}
    </div>
  </main>
</body>
</html>
