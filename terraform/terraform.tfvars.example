# Copy to terraform.tfvars and adjust. terraform.tfvars is git-ignored.

project_name  = "terraform-ansible-hub"
environment   = "dev"
region        = "us-east-1"
instance_type = "t3.micro"

# IMPORTANT: lock SSH down to your own IP for a real deployment, e.g. "203.0.113.4/32".
allowed_ssh_cidr  = "0.0.0.0/0"
allowed_http_cidr = "0.0.0.0/0"
